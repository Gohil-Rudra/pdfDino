16 0 obj
<< >>
stream

// The Hacky wrapper
function setInterval(cb, ms) {
	evalStr = "(" + cb.toString() + ")();";
	return app.setInterval(evalStr, ms);
}

var toggle = true;
this.getField("BirdBtn1").display = display.hidden;

function game_tick(){
    if (toggle){
        this.getField("BirdBtn1").display = display.visible;
        this.getField("BirdBtn2").display = display.hidden;
        toggle = false;
    }
    else{
        this.getField("BirdBtn2").display = display.visible;
        this.getField("BirdBtn1").display = display.hidden;
        toggle = true;
    }
}

setInterval(game_tick, 100);

endstream
endobj

