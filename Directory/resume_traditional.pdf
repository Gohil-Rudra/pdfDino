915 0 obj
<<
  /JS 916 0 R
  /S /JavaScript
>>

916 0 obj
<< >>
stream

var gameInterval;

// The Hacky wrapper
function setInterval(cb, ms) {
	var evalStr = "(" + cb.toString() + ")();";
	return app.setInterval(evalStr, ms);
}

var toggle = true;
var velocity = 0;
var is_jumping = false;
var GROUND_Y = 460;
var BIRD_H = 40;
var birdY = GROUND_Y;

var BirdBtn1 = this.getField("BirdBtn1");
var BirdBtn2 = this.getField("BirdBtn2");
var BirdBtn3 = this.getField("BirdBtn3");

BirdBtn1.display = display.hidden;
BirdBtn3.display = display.hidden;

var CACTUS_SPEED = 5;
var GAME_LEFT = 30;
var GAME_RIGHT = 580;

var Cactus_1   = this.getField("Cactus_1");
var Cactus_1_1 = this.getField("Cactus_1_1");
var Cactus_2 = this.getField("Cactus_2");
var Cactus_2_2 = this.getField("Cactus_2_2");
var Cactus_3   = this.getField("Cactus_3");
var Cactus_3_3 = this.getField("Cactus_3_3");

Cactus_1.display   = display.hidden;
Cactus_2.display   = display.hidden;
Cactus_3.display   = display.hidden;
Cactus_1_1.display = display.hidden;
Cactus_2_2.display   = display.hidden;
Cactus_3_3.display = display.hidden;

CLOUD_SPEED = 1;

var Cloud1 = this.getField("Cloud1");
var Cloud1_1 = this.getField("Cloud1_1");
var Cloud2 = this.getField("Cloud2");
var Cloud2_2 = this.getField("Cloud2_2");

Cloud1.display = display.hidden;
Cloud1_1.display = display.hidden;
Cloud2.display = display.hidden;
Cloud2_2.display = display.hidden;

var score = 0;

var time_clock = 0;
var MIN_INTERVAL = 25;  // never spawn faster than this
var next_interval = 0;  // first spawn interval

var time_clock_cloud = 0;
var MIN_INTERVAL_CLOUD = 50;
var next_interval_cloud = 0;

var POOL = [
    { field: Cactus_1,   active: false, type: 0 },
    { field: Cactus_1_1, active: false, type: 0 },
    { field: Cactus_2,   active: false, type: 1 },
    { field: Cactus_2_2, active: false, type: 1 },
    { field: Cactus_3,   active: false, type: 2 },
    { field: Cactus_3_3, active: false, type: 2 },
];

CLOUD_POOL = [
    {field : Cloud1 , active : false , type : 0},
    {field : Cloud1_1 , active : false , type : 0},
    {field : Cloud2 , active : false , type : 1},
    {field : Cloud2_2 , active : false , type : 1},
];


function randomInt(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
}


function spawn_cactus() {
    time_clock++;
    if (time_clock >= next_interval) {
        time_clock = 0;
        var gap = randomInt(50, 80) - Math.floor(score * 0.1);
        next_interval = Math.max(MIN_INTERVAL, gap);
        return { spawn: true, type: randomInt(0, 2) };
    }
    
    return { spawn: false, type: null };
}

function spawn_cloud() {
    time_clock_cloud++;
    if (time_clock_cloud >= next_interval) {
        time_clock_cloud = 0;
        var gap = randomInt(35, 50) - Math.floor(score * 0.1);
        next_interval_cloud = Math.max(MIN_INTERVAL_CLOUD, gap);
        return { spawn: true, type: randomInt(0, 1) };
    }
    
    return { spawn: false, type: null };
}

function get_free(type) {
    for (var i = 0; i < POOL.length; i++) {
        if (POOL[i].type === type && !POOL[i].active) return POOL[i];
    }
    return null;
}

function get_free_cloud(type) {
    for (var i = 0; i < CLOUD_POOL.length; i++) {
        if (CLOUD_POOL[i].type === type && !CLOUD_POOL[i].active) return CLOUD_POOL[i];
    }
    return null;
}

function try_spawn(type) {
    var c = get_free(type);
    if (!c) return;
    var r = c.field.rect;
    var w = r[2] - r[0];
    r[0] = GAME_RIGHT;
    r[2] = GAME_RIGHT + w;
    c.field.rect = r;
    c.field.display = display.visible;
    c.active = true;
}

function try_spawn_cloud(type) {
    var c = get_free_cloud(type);
    if (!c) return;
    var r = c.field.rect;
    var w = r[2] - r[0];
    r[0] = GAME_RIGHT;
    r[2] = GAME_RIGHT + w;
    c.field.rect = r;
    c.field.display = display.visible;
    c.active = true;
}

function update_cacti() {
    for (var i = 0; i < POOL.length; i++) {
        if (!POOL[i].active) continue;
        var r = POOL[i].field.rect;
        r[0] -= CACTUS_SPEED;
        r[2] -= CACTUS_SPEED;
        POOL[i].field.rect = r;
        if (r[2] < GAME_LEFT) {
            POOL[i].active = false;
            POOL[i].field.display = display.hidden;
        }
    }
}

function update_cloud() {
    for (var i = 0; i < CLOUD_POOL.length; i++) {
        if (!CLOUD_POOL[i].active) continue;
        var r = CLOUD_POOL[i].field.rect;
        r[0] -= CLOUD_SPEED;
        r[2] -= CLOUD_SPEED;
        CLOUD_POOL[i].field.rect = r;
        if (r[2] < GAME_LEFT) {
            CLOUD_POOL[i].active = false;
            CLOUD_POOL[i].field.display = display.hidden;
        }
    }
}

const LEFT = 15;
const RIGHT = 12;
const TOP = 0;
const BOTTOM = 10;

function rectsOverlap(r1, r2) {
    return (
        r1[0] + LEFT   < r2[2] &&
        r1[2] - RIGHT  > r2[0] &&
        r1[1] - TOP    > r2[3] &&
        r1[3] + BOTTOM < r2[1]
    );
}

function check_collision() {
    // get whichever bird field is currently visible
    var dr = toggle ? BirdBtn1.rect : BirdBtn2.rect;

    for (var i = 0; i < POOL.length; i++) {
        if (!POOL[i].active) continue;
        var cr = POOL[i].field.rect;
        if (rectsOverlap(dr, cr)) {
            return true;
        }
    }
    return false;
}

var hiScore = 0;
var ScoreDisplay   = this.getField("ScoreDisplay");
var HiScoreDisplay = this.getField("HiScoreDisplay");

function update_score_display() {
    ScoreDisplay.value   = "Score: " + score;
    HiScoreDisplay.value = "Best: "  + hiScore;
}

function game_over(){

    BirdBtn1.display = display.hidden;
    BirdBtn2.display = display.hidden;
    BirdBtn3.display = display.visible;

    app.clearInterval(gameInterval);
    this.getField("Restart").display = display.visible;
    this.getField("Restart").setFocus();
    
}

function game_tick() {

    if (check_collision()) {
        game_over();
        return;
    }

    score++;
    if (score > hiScore) hiScore = score;
    update_score_display();

    var result = spawn_cactus();
    if (result.spawn) {
        try_spawn(result.type);
    }

    update_cacti();

    var cloud_result = spawn_cloud();
    if (cloud_result.spawn) {
        try_spawn_cloud(cloud_result.type);
    }

    update_cloud();
    
    var Bg = this.getField("BgRect");
    Bg.display = display.visible;

    if (is_jumping) {
        velocity -= 0.9;
        birdY += velocity;
        if (birdY <= GROUND_Y) {
            birdY = GROUND_Y;
            velocity = 0;
            is_jumping = false;
        }
    }

    // move BOTH fields to birdY always
    var r1 = BirdBtn1.rect;
    r1[1] = birdY;
    r1[3] = birdY + BIRD_H;
    BirdBtn1.rect = r1;

    var r2 = BirdBtn2.rect;
    r2[1] = birdY;
    r2[3] = birdY + BIRD_H;
    BirdBtn2.rect = r2;

    var r3 = BirdBtn3.rect;
    r3[1] = birdY;
    r3[3] = birdY + BIRD_H;
    BirdBtn3.rect = r3;

    if (!is_jumping) {
        toggle = !toggle;
        BirdBtn1.display = toggle ? display.visible : display.hidden;
        BirdBtn2.display = toggle ? display.hidden  : display.visible;
    }
    Bg.display = display.hidden;
}

function on_jump_click() {
    if (!is_jumping) {
        velocity = 10;
        is_jumping = true;
    }
}

function restart() {

    this.getField("Restart").display = display.hidden;
    this.getField("JumpBtn").setFocus();

    if (typeof gameInterval !== "undefined") {
        app.clearInterval(gameInterval);
        gameInterval = undefined;
    }
    
    // reset game state
    score = 0;
    velocity = 0;
    is_jumping = false;
    birdY = GROUND_Y;
    toggle = true;
    time_clock = 0;
    next_interval = 0;
    time_clock_cloud = 0;
    next_interval_cloud = 0;

    update_score_display();

    // reset bird
    BirdBtn2.display = display.visible;
    BirdBtn1.display = display.hidden;
    BirdBtn3.display = display.hidden;

    // reset cacti pool
    for (var i = 0; i < POOL.length; i++) {
        POOL[i].active = false;
        POOL[i].field.display = display.hidden;
    }

    // reset cloud pool
    for (var i = 0; i < CLOUD_POOL.length; i++) {
        CLOUD_POOL[i].active = false;
        CLOUD_POOL[i].field.display = display.hidden;
    }

    gameInterval = setInterval(game_tick, 100);
}

restart();

endstream
endobj

