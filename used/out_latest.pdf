42 0 obj
<< >>
stream

// Hacky wrapper to work with a callback instead of a string 

function setInterval(cb, ms) {
	evalStr = "(" + cb.toString() + ")();";
	return app.setInterval(evalStr, ms);
}

function clearFrameBuffer(HEIGHT,WIDTH)
{
    for (let y = 0; y < HEIGHT; y++){
        FRAME_BUFFER[y] = [];

        for (let x = 0; x < WIDTH; x++){
            FRAME_BUFFER[y][x] = ' ';
        }
    }    
}

var CACTUS = `
    ,*-.
    |  |
,.  |  |
| |_|  | ,.
\`---.  |_| |
    |  .--\`
    |  |
    |  |
`;

CACTUS = CACTUS.split('
');
var CACTUS_COORDINATES = [];
var CACTUS_SPRITE = []; 

for (let y = 0; y < CACTUS.length; y++)
{
    for (let x = 0; x < CACTUS[y].length; x++)
    {
        if (CACTUS[y][x] !== ' ')
        {
            CACTUS_COORDINATES.push([
                x,
                y,
                CACTUS[y][x]
            ]);
        }
    }
}


var minX = Infinity;
var minY = Infinity;

for (let i = 0; i < CACTUS_COORDINATES.length; i++)
{
    minX = Math.min(minX, CACTUS_COORDINATES[i][0]);
    minY = Math.min(minY, CACTUS_COORDINATES[i][1]);
}



for (let i = 0; i < CACTUS_COORDINATES.length; i++)
{
    let x = CACTUS_COORDINATES[i][0] - minX;
    let y = CACTUS_COORDINATES[i][1] - minY;
    let ch = CACTUS_COORDINATES[i][2];

    CACTUS_SPRITE.push([x, y, ch]);
}

function drawCACTUS(xNew)
{
    for (let i = 0; i < CACTUS_SPRITE.length; i++)
    {
        let x  = CACTUS_SPRITE[i][0];
        let y  = CACTUS_SPRITE[i][1];
        let ch = CACTUS_SPRITE[i][2];

        let px = xNew + x;

        if (
            px >= 0 &&
            px < FRAME_BUFFER[0].length &&
            y >= 0 &&
            y < FRAME_BUFFER.length
        )
        {
            FRAME_BUFFER[y][px] = ch;
        }
    }
}

function framebufferToString()
{
    let output = "";

    for (let y = 0; y < FRAME_BUFFER.length; y++)
    {
        output += FRAME_BUFFER[y].join("") + "";
    }

    return output;
}


var cactusX = 50; // for now lets say it will move from position 50
var FRAME_BUFFER = [];
var score = 0;
var time_ms = 0;
var last_update = 0;
var interval = 0;
var TICK_INTERVAL = 50;
var GAME_STEP_TIME = 400;

function set_controls_visibility(state) {
	this.getField("T_input").hidden = !state;
	this.getField("B_up").hidden = !state;
}

var HEIGHT;
var WIDTH;

function game_init() {

	HEIGHT = 250;
	WIDTH = 800;
	clearFrameBuffer(HEIGHT,WIDTH);
	last_update = time_ms;
	score = 0;

	// Start timer
	interval = setInterval(game_tick, TICK_INTERVAL);

	// Hide start button
	this.getField("B_start").hidden = true;

	// Show input box and controls
	set_controls_visibility(true);
}

function game_over() {
	app.clearInterval(interval);
	app.alert(`Game over! Score: ${score}
Refresh to restart.`);
}

function draw_updated_score() {
	this.getField("T_score").value = `Score: ${score}`;
}

function render()
{
    var screen = this.getField("SCREEN");

    if (!screen)
        return;

    screen.value = framebufferToString();
}

function game_tick(){
    time_ms += TICK_INTERVAL;
    clearFrameBuffer(HEIGHT,WIDTH);
    drawCACTUS(cactusX);
    render();
    cactusX--;
}

// Hide controls to start with
set_controls_visibility(false);

// Zoom to fit (on FF)
app.execMenuItem("FitPage");

endstream
endobj


